<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AntiGravity" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.AntiGravity.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A237E</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.AntiGravity</item>
    </style>
</resources>
